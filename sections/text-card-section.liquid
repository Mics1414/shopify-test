{% assign section_id = "#shopify-section-" | append: section.id %}

<style>
  {{ section_id }} .container {
    max-width: 1440px;
    padding: 10px;
  }

  {{ section_id }} .mx-auto {
    margin-inline: auto;
  }

  {{ section_id }} .text-intro-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  {{ section_id }} .text-intro-wrapper h2 {
    font-size: 36px;
    font-weight: 600;      
    line-height: 44px; 
    color: #4D4D4D;
    margin: 0px;
  }

  {{ section_id }} .text-intro-wrapper p {
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
    color: #717171;
    margin: 0px;
  }

  {{ section_id }} .card-text-wrapper h2 {
    font-size: 28px;
    line-height: 36px;
    margin: 0px;
  }

  {{ section_id }} .card-text-wrapper p {
    font-size: 14px;
    font-weight: 400;
    line-height: 20px;
    color: #717171;
    margin: 0px;
  }

  {{ section_id }} .showcase-page-content {
    padding: 20px 0px 21px 0px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  {{ section_id }} .card-image-text-wrapper {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    gap: 127.5px;
  }

  {{ section_id }} .card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    justify-content: center;
    max-width: 299px;
    width: 100%;
    height: 280px;
    gap: 8px;
    box-shadow: 0px 2px 4px rgba(171, 190, 209, 0.2);
  }

    

</style>

<div class="card-showcase">
  <div class="container mx-auto">
    <div class="showcase-page-content">
      <div class="text-intro-wrapper">
        <h2>
          {{  section.settings.header_text  }}
        </h2>
        <p>
          {{ section.settings.desc_text }}
        </p>
      </div>

        <div class="card-image-text-wrapper">
          {% for block in section.blocks %}
            <div class="card">
              {% if block.settings.card_logo %}
                {{ block.settings.card_logo | image_url: width: 65 | image_tag }}
              {% endif %}
              <div class="card-text-wrapper">
                <h2>
                  {{  block.settings.card_header_text  }}
                </h2>
                <p>
                  {{ block.settings.card_desc_text }}
                </p>
              </div> 
            </div>
          {% endfor %}
        </div>

    </div>
  </div>
</div>

{% schema %} 
  {
  "name": "Card Showcase",
  "settings": [
    {
     "type": "text",
      "id": "header_text",
      "label": "Header Text"
    },
    {
     "type": "text",
      "id": "desc_text",
      "label": "Description Text"
    }
    ],
    "blocks": [
      {
       "type": "cards",
       "name": "Cards",
       "settings": [
          {
           "type": "text",
           "id": "card_header_text",
           "label": "Header Text"
          },
          {
           "type": "text",
           "id": "card_desc_text",
           "label": "Description Text"
          },
          {
           "type": "image_picker",
           "id": "card_logo",
           "label": "Logo"
          }
        ]
      }
      ],
      "presets": [
      {
        "name": "Card Showcase"
      }
    ]
  }
{% endschema %}