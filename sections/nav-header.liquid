{% assign section_id = "#shopify-section-" | append: section.id %}

<style>
  {{ section_id }} .container {
    max-width: 1440px;
    padding: 0px 10px;
  }

  {{ section_id }} .mx-auto {
    margin-inline: auto;
  }

  {{ section_id }} .button-wrapper {
  display: flex;
  flex-direction: row;
  gap: 14px;
  }

  {{ section_id }} .content-wrapper {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    padding: 22px 0px;
  }

  {{ section_id }} .logo-wrapper img {
    max-width: 155px;
    width: 100%;
    height: auto;
  }

  {{ section_id }} .menu-wrapper {
    display: flex;
    align-items: center;
  }

  {{ section_id }} .menu-list {
    display: flex;
    align-items: center;
    gap: 50px;
    margin: 0px;
    padding: 0px;
    list-style: none;
  }

  {{ section_id }} .menu-item a {
    text-decoration: none;
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
    color: #18191F;
  }

  {{ section_id }} .button-wrapper {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  {{ section_id }} .button-one,
  {{ section_id }} .button-two {
    padding: 10px 20px;
    border-radius: 6px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
  }

  {{ section_id }} .button-one {
    color: #4CAF4F;
    background-color: transparent;
  }

  {{ section_id }} .button-two {
    color: #FFFFFF;
    background-color: #4CAF4F;
  }
</style>

<div class="nav-header-wrapper">
  <div class="container mx-auto">
    <div class="content-wrapper">
      <div class="logo-wrapper">
        {% if section.settings.nav_logo %}
          {{ section.settings.nav_logo | image_url: width: 155 | image_tag }}
        {% endif %}
      </div>

      <div class="menu-wrapper">
        <ul class="menu-list">
          {% for link in section.settings.menu_lists.links %}
            <li class="menu-item">
              <a href="{{ link.url }}">{{ link.title }}</a>
            </li>
          {% endfor %}
        </ul>
      </div>

      <div class="button-wrapper">
        {% if section.settings.button_one_text != blank %}
          <a href="{{ section.settings.button_one_link }}" class="button-one">
            {{ section.settings.button_one_text }}
          </a>
        {% endif %}

        {% if section.settings.button_two_text != blank %}
          <a href="{{ section.settings.button_two_link }}" class="button-two">
            {{ section.settings.button_two_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
 "name": "Nav Header",
 "tag": "section",
 "class": "nav-header",
 "settings": [
    {
     "type": "image_picker",
     "id": "nav_logo",
     "label": "Navigation Logo"
    },
    {
     "type": "link_list",
     "id": "menu_lists",
     "label": "Navigation Menu"
    },
    {
     "type": "header",
     "content": "Button One"
    },
    {
     "type": "text",
     "id": "button_one_text",
     "label": "Button Text",
     "default": "Login"
    },
    {
     "type": "url",
     "id": "button_one_link",
     "label": "Button Link"
    },
    {
     "type": "header",
     "content": "Button Two"
    },
    {
     "type": "text",
     "id": "button_two_text",
     "label": "Button Text",
     "default": "Sign Up"
    },
    {
     "type": "url",
     "id": "button_two_link",
     "label": "Button Link"
    }
  ],
  "presets": [
    {
     "name": "Nav Header"
    }
  ]
}
{% endschema %}