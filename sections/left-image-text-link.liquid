{% assign section_id = "#shopify-section-" | append: section.id %}

<style>
  {{ section_id }} .container {
    max-width: 1440px;
    padding: 0px 10px;
  }

  {{ section_id }} .mx-auto {
    margin-inline: auto;
  }

  {{ section_id }} .text-link-wrapper h2 {
    font-size: 42px;
    font-weight: 600;      
    line-height: 100%; 
    height: 104px;
    color: #1E1E1E;
    margin: 0px;
  }

  {{ section_id }} .text-link-wrapper strong {
    font-size: 18px;
    font-weight: 600;      
    line-height: 100%; 
    letter-spacing: 17.5%;
    color: #E58411;
    margin: 0px;
  }

  {{ section_id }} .text-link-wrapper p {
    font-size: 18px;
    font-weight: 400;
    line-height: 185%;
    color: #1E1E1E;
    margin: 0px;
  }

  {{ section_id }} .text-link-wrapper {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  {{ section_id }} .learn-more-btn {
    text-decoration: none;
    font-size: 16px;
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 52px;
    color: #FFFFFF;
  }

   {{ section_id }} .more-info{
      font-size: 14px;
      font-weight: 600;      
      line-height: 185%; 
      letter-spacing: 17.5%;
      color: #E58411;
      text-decoration: none;
      margin: 0px;
  }

  {{ section_id }} .section-page-content {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 49px;
    padding: 42px 0px;
    justify-content: space-between;
  }

</style>


<div class="image-text-link-section">
  <div class="container mx-auto">
    <div class="section-page-content">
      <div class="media-wrapper">
          {% if section.settings.image_id %}
            {{ section.settings.image_id | image_url: width: 442 | image_tag }}
          {% endif %}
        </div>
      <div class="text-link-wrapper">
        <h2>
          {{  section.settings.header_text  }}
        </h2>
        <p>
          {{ section.settings.desc_text }}
        </p>

        <div class="link-wrapper">
          <a href="{{ section.settings.link_url }}" class="more-info">
            {{ section.settings.link_text }}

            {% if section.settings.link_image %}
              {{ section.settings.link_image | image_url: width: 38 | image_tag }}
            {% endif %}
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image Text Link",
  "settings": [
    {
     "type": "richtext",
      "id": "header_text",
      "label": "Header Text"
    },
    {
     "type": "text",
      "id": "desc_text",
      "label": "Description Text"
    },
    {
     "type": "image_picker",
     "id": "image_id",
     "label": "Image"
    },
    {
     "type": "text",
     "id": "link_text",
     "label": "Link Text"
    },
    {
     "type": "url",          
     "id": "link_url",
     "label": "Link URL"
    },
    {
     "type": "image_picker",
     "id": "link_image",
     "label": "Link Image"
    }
  ],  
  "presets": [
    {
      "name": "Left Image with Text and Link"
    }
  ]
}

{% endschema %}