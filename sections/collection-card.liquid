{% assign section_id = "#shopify-section-" | append: section.id %}

<style>
  {{ section_id }} .container {
    max-width: 1440px;
    padding: 0px 10px;
  }

  {{ section_id }} .mx-auto {
    margin-inline: auto;
  }

  {{ section_id }} .intro-text-wrapper h2 {
    font-size: 36px;
    font-weight: 600;      
    line-height: 44px; 
    color: #4D4D4D;
    margin: 0px;
  }

  {{ section_id }} .card-text-wrapper h2 {
    font-size: 20px;
    font-weight: 600;
    line-height: 28px;
    text-align: center;
    color: #717171;
  }

  {{ section_id }} .intro-text-wrapper p {
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
    color: #717171;
    margin: 0px;
    max-width: 628px;
    width: 100%;
    text-align: center;
    color: #717171;
  }

  {{ section_id }} .intro-text-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  {{ section_id }} .card-image-text-wrapper {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    gap: 24px;
  }
  
  {{ section_id }} .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: 40px;
    padding: 48px 0px 94.6px 0px;
  }

  {{ section_id }} .card, .card img {
    max-width: 386px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  {{ section_id }} .card-text-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 317px;
    width: 100%;
    height: 176px;
    gap: 16px;
    align-items: center;
    background-color: #F5F7FA;
    z-index: 10;
    transform: translateY(-100px);
    border-radius: 8px;
    justify-content: center;
    box-shadow: 0px 8px 16px rgba(171, 190, 209, 0.4);
  }

  {{ section_id }} .button-wrapper {
    font-size: 20px;
    font-weight: 600;
    line-height: 28px;
    gap: 8px;
  }

  {{ section_id }} .button-wrapper a {
    display: flex;
    justify-content: center;
    justify-content: center;
    flex-direction: row;
    text-decoration: none;
    font-size: 20px;
    font-weight: 600;
    line-height: 28px;
    gap: 8px;
    color: #4CAF4F;
  }

</style>

<div class="collection-card">
  <div class="container mx-auto">
    <div class="showcase-page-content">
      <div class="content-wrapper">
        <div class="intro-text-wrapper">
          <h2>
            {{  section.settings.header_text  }}
          </h2>
          <p>
            {{ section.settings.desc_text }}
          </p>
        </div>

        <div class="card-image-text-wrapper">
          {% for block in section.blocks %}
            <div class="card">
              {% if block.settings.card_logo %}
                {{ block.settings.card_logo | image_url: width: 368 | image_tag }}
              {% endif %}
              <div class="card-text-wrapper">
                <h2>
                  {{  block.settings.card_header_text  }}
                </h2>
                
                <div class="button-wrapper">
                  {% if block.settings.button_logo %}
                    <a href="{{ block.settings.button_link }}" class="arrow-btn">{{ block.settings.button_text }}<span>{{ block.settings.button_logo | image_url: width: 28 | image_tag }}</span></a>
                  {% endif %}
                </div>
              </div> 
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %} 
  {
  "name": "Card Showcase",
  "settings": [
    {
     "type": "text",
      "id": "header_text",
      "label": "Header Text"
    },
    {
     "type": "text",
      "id": "desc_text",
      "label": "Description Text"
    }
    ],
    "blocks": [
      {
       "type": "cards",
       "name": "Card",
       "settings": [
          {
           "type": "image_picker",
           "id": "card_logo",
           "label": "Image"
          },
          {
           "type": "text",
           "id": "card_header_text",
           "label": "Header Text"
          },
          {
           "type": "image_picker",
           "id": "button_logo",
           "label": "Button Logo"
          },
          {
           "type": "text",
           "id": "button_text",
           "label": "Button Text"
          },
          {
           "type": "url",
           "id": "button_link",
           "label": "Button Link"
          }
        ]
      }
      ],
      "presets": [
      {
        "name": "Text and Collection Cards"
      }
    ]
  }
{% endschema %}